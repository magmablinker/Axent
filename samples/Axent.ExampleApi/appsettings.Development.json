{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Axent": "Debug"
    }
  },
  "AppSettings": {
    "Axent": {
      "ErrorHandling": {
        "EnableDetailedExceptionResponse": true
      },
      "Logging": {
        "EnableRequestLogging": true
      }
    }
  }
}
