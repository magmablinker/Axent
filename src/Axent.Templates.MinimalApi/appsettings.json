{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Axent": {
    "ErrorHandling": {
      "EnableDetailedExceptionResponse": false
    },
    "Logging": {
      "EnableRequestLogging": false
    },
    "Transactions": {
      "UseTransactions": true
    }
  }
}
